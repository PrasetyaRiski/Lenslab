# Copy this file to .env.production on your server and fill real values there.
# Never commit .env.production with real secrets.

POSTGRES_USER=lenslab_user
POSTGRES_PASSWORD=change-me
POSTGRES_DB=lenslab_db
DATABASE_URL=postgresql://lenslab_user:change-me@localhost:5432/lenslab_db?schema=public
APP_PORT=3000

NEXT_PUBLIC_APP_URL=https://your-domain.example
JWT_SECRET=replace-with-a-long-random-secret

GOOGLE_AUTH_CLIENT_ID=
GOOGLE_AUTH_CLIENT_SECRET=
GOOGLE_AUTH_REDIRECT_URI=https://your-domain.example/api/auth/google/callback

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_REFRESH_TOKEN=
GOOGLE_DRIVE_ROOT_FOLDER_ID=

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

PRISMA_DB_PUSH=true
SEED_DEFAULT_USERS=true
SEED_DEFAULT_PASSWORD=password123
