# Database
POSTGRES_USER=lenslab_user
POSTGRES_PASSWORD=change-me
POSTGRES_DB=lenslab_db
DATABASE_URL="postgresql://lenslab_user:change-me@localhost:5432/lenslab_db?schema=public"

# App
APP_PORT=3000
NEXT_PUBLIC_APP_URL="http://localhost:3000"
JWT_SECRET="replace-with-a-long-random-secret"

# Google OAuth
GOOGLE_AUTH_CLIENT_ID=""
GOOGLE_AUTH_CLIENT_SECRET=""
GOOGLE_AUTH_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"

# Google Drive uploads, optional
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI=""
GOOGLE_REFRESH_TOKEN=""
GOOGLE_DRIVE_ROOT_FOLDER_ID=""

# Gemini AI, optional
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"
GEMINI_BASE_URL="https://generativelanguage.googleapis.com/v1beta"

# Docker startup helpers
PRISMA_DB_PUSH=true
SEED_DEFAULT_USERS=true
SEED_DEFAULT_PASSWORD=password123
